<% layout("layouts/boilerplate") %>
<body> 
    <div class="row mt-3">
        <div class="col-8 offset-3"> <!--  Creating a col of size 8  and offset-2 for in center-->
            <h3><%= listing.title %></h3>
        </div>    
            <div class="card col-6 offset-3 show-card listing-card">
                <img src="<%= listing.image %>" class="card-img-top show-img" alt="Lisitng-image">
                <div class="card-body mt-2">
                    <%= listing.description %> <br>
                    &#8377; <%= listing.price.toLocaleString("en-IN") %> <br>
                    <%= listing.location %> <br>
                    <%= listing.country %> <br>
                    </div>
            </div>
    </div>
    <div class="btns">
        <!-- Edit the Lisitngs  -->
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn mb-4">Edit</a><br>

        <!-- Deleting the listings -->
        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" >
            <button class="btn btn-dark offset-5 mb-4">Delete</button>
        </form>
    </div>

    <!-- Review Section -->
    <div class="col-8 offset-3 mb-3">
        <hr>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
                <label for="rating" class="form-label">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
            <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea id="comq" name="review[comment]" class="form-control" cols="30" rows="5" required></textarea>
                <div class="invalid-feedback">Please add some comments for review</div>
            </div>
            <button class="btn btn-outline-dark">Submit</button>
        </form>

        <hr>
        <p><b>All Reviews</b></p>
        <div class="row">
            <% for(let review of listing.reviews) { %>
                <div class="card col-5 ms-3 mb-3 ">
                    <div class="card-body ">
                        <div class="card-title">Joe James</div>
                        <div class="card-text"><%= review.comment %></div>
                        <div class="card-text"><%= review.rating %> stars</div>
    
                    </div>
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3" method="post">
                        <button class="btn btn-sm btn-dark">Delete</button>
                    </form>
                </div>
            <% } %>
        </div>

    </div>
    
</body>
